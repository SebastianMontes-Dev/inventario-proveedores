# Plantilla de variables de entorno del backend.
# Copia este archivo a backend/.env (o expórtalas en tu shell) y ajusta los valores.
# NO commitees el .env real con secretos.

# --- Base de datos ---
DB_URL=jdbc:mysql://localhost:3306/inventario_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=inventario
DB_PASSWORD=inventario123

# --- Seguridad / JWT ---
# Obligatorio. Minimo 32 caracteres. El backend NO arranca si falta o es debil.
JWT_SECRET=cambia-esto-por-un-valor-aleatorio-de-32-caracteres-o-mas
JWT_EXPIRATION_MINUTES=480

# --- CORS ---
# Origenes del frontend permitidos (separados por coma si hay varios).
CORS_ORIGINS=http://localhost:4200

# --- Cookie de sesion (access_token, HttpOnly) ---
# cookie-secure=true exige HTTPS. cookie-same-site: Strict/Lax si front y back comparten
# sitio; None (con cookie-secure=true) si estan en dominios distintos.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Strict

# --- Otros ---
APP_TIME_ZONE=America/Bogota
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@inventario.local
OPS_EMAIL=admin@inventario.local
